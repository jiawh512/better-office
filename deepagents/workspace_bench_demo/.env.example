# ============================================================
# API Keys (required)
# ============================================================

# Inner Agent + Better Agent API (Moonshot)
OPENAI_API_KEY=sk-your-moonshot-key
OPENAI_API_BASE=https://api.moonshot.cn/v1

# Judge API (DeepSeek)
JUDGE_API_KEY=sk-your-deepseek-key
JUDGE_BASE_URL=https://api.deepseek.com

# Optional: separate API key for Better Agent (falls back to OPENAI_API_KEY)
# BETTER_AGENT_API_KEY=sk-your-key
# BETTER_AGENT_API_BASE=https://api.moonshot.cn/v1

# ============================================================
# Model Config (optional overrides)
# ============================================================

# INNER_AGENT_MODEL=deepseek-chat
# JUDGE_MODEL=deepseek-chat

# ============================================================
# Path Overrides (only change if you mount volumes differently)
# ============================================================

# WB_TASK_ROOT=/workspace/Workspace-Bench/evaluation/tasks_lite
# WB_EVAL_SRC=/workspace/Workspace-Bench/evaluation/src
# BETTER_HARNESS_ROOT=/workspace/better-harness